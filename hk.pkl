amends "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Config.pkl"

hooks {
  ["pre-push"] {
    steps {
      ["test"] {
        check = "if [ \"$(git branch --show-current)\" = \"main\" ]; then rake test; fi"
      }
      ["check-format"] {
        check = "if [ \"$(git branch --show-current)\" = \"main\" ]; then rake check_format; fi"
      }
      ["lint"] {
        check = "if [ \"$(git branch --show-current)\" = \"main\" ]; then rake lint; fi"
      }
    }
  }
}
