amends "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Config.pkl"

// TODO: mainでのみ実行するようにする
hooks {
  ["pre-push"] {
    steps {
      ["test"] {
        check = "rake test"
      }
      ["check-format"] {
        check = "rake check_format"
      }
      ["lint"] {
        check = "rake lint"
      }
    }
  }
}
